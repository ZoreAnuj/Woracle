        "channel": {
          "title": "Channel",
          "type": "string"
        },
        "confidence": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "details": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Details",
          "type": "object"
        },
        "reason": {
          "default": "",
          "title": "Reason",
          "type": "string"
        },
        "series": {
          "additionalProperties": {
            "items": {
              "type": "number"
            },
            "type": "array"
          },
          "title": "Series",
          "type": "object"
        },
        "status": {
          "default": "ok",
          "enum": [
            "ok",
            "evidence_missing",
            "skipped"
          ],
          "title": "Status",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "channel"
      ],
      "title": "ChannelScore",
      "type": "object"
    },
    "GateReport": {
