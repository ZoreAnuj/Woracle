{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "description": "Reference to a sidecar payload file (npz / parquet / mp4 / safetensors).\n\n``path`` is relative to the directory of the JSON document that holds the\nref, so artifact bundles stay relocatable.",
      "properties": {
        "kind": {
          "default": "",
          "title": "Kind",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "default": "",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "RolloutRef": {
      "additionalProperties": false,
      "description": "A single episode (generated rollout or demonstration).",
      "properties": {
        "actions": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "fps": {
          "default": 10.0,
          "title": "Fps",
          "type": "number"
        },
        "frames": {
          "$ref": "#/$defs/ArtifactRef"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "meta": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Meta",
          "type": "object"
        },
        "n_frames": {
          "default": 0,
          "title": "N Frames",
          "type": "integer"
        },
        "policy": {
          "default": "",
          "title": "Policy",
          "type": "string"
        },
        "schema_version": {
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "source": {
          "default": "",
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "id",
        "frames"
      ],
      "title": "RolloutRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "A small set of demonstrations for one task (Stage-1 input).",
  "properties": {
    "demos": {
      "items": {
        "$ref": "#/$defs/RolloutRef"
      },
      "title": "Demos",
      "type": "array"
    },
    "labels": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Labels",
      "type": "object"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "task": {
      "title": "Task",
      "type": "string"
    }
  },
  "required": [
    "task",
    "demos"
  ],
  "title": "DemoSet",
  "type": "object"
}
