{
  "$defs": {
    "FailureMode": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "signature": {
          "items": {
            "$ref": "#/$defs/Predicate"
          },
          "title": "Signature",
          "type": "array"
        }
      },
      "required": [
        "name"
      ],
      "title": "FailureMode",
      "type": "object"
    },
    "Phase": {
      "additionalProperties": false,
      "properties": {
        "active": {
          "items": {
            "$ref": "#/$defs/Predicate"
          },
          "title": "Active",
          "type": "array"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "order": {
          "default": 0,
          "title": "Order",
          "type": "integer"
        }
      },
      "required": [
        "name"
      ],
      "title": "Phase",
      "type": "object"
    },
    "Predicate": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "contained",
            "co_located",
            "stationary",
            "approaching",
            "separated",
            "present"
          ],
          "title": "Kind",
          "type": "string"
        },
        "object": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Object"
        },
        "params": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Params",
          "type": "object"
        },
        "subject": {
          "title": "Subject",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "subject"
      ],
      "title": "Predicate",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "description": "Who/what produced an artifact. Embedded in every output document.",
      "properties": {
        "components": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Components",
          "type": "object"
        },
        "created_at": {
          "default": "",
          "title": "Created At",
          "type": "string"
        },
        "extra": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Extra",
          "type": "object"
        },
        "git_sha": {
          "default": "",
          "title": "Git Sha",
          "type": "string"
        },
        "package_version": {
          "default": "",
          "title": "Package Version",
          "type": "string"
        }
      },
      "title": "Provenance",
      "type": "object"
    },
    "Role": {
      "additionalProperties": false,
      "description": "A relational participant in the task \u2014 never an appearance.",
      "properties": {
        "candidates": {
          "items": {
            "type": "string"
          },
          "title": "Candidates",
          "type": "array"
        },
        "definition": {
          "title": "Definition",
          "type": "string"
        },
        "motion": {
          "default": "free",
          "enum": [
            "co_moves_with_effector",
            "static",
            "actuated",
            "free"
          ],
          "title": "Motion",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "definition"
      ],
      "title": "Role",
      "type": "object"
    },
    "SelfTestReport": {
      "additionalProperties": false,
      "description": "Result of the compile-time self-test (P4): demos must pass, minted\nnegatives must fail. Recorded so every spec carries its own validation.",
      "properties": {
        "accepted": {
          "default": false,
          "title": "Accepted",
          "type": "boolean"
        },
        "demos_passed": {
          "default": 0,
          "title": "Demos Passed",
          "type": "integer"
        },
        "demos_total": {
          "default": 0,
          "title": "Demos Total",
          "type": "integer"
        },
        "negatives_failed": {
          "default": 0,
          "title": "Negatives Failed",
          "type": "integer"
        },
        "negatives_total": {
          "default": 0,
          "title": "Negatives Total",
          "type": "integer"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "ran": {
          "default": false,
          "title": "Ran",
          "type": "boolean"
        }
      },
      "title": "SelfTestReport",
      "type": "object"
    },
    "SpecProvenance": {
      "additionalProperties": false,
      "properties": {
        "compiler": {
          "default": "handwritten",
          "title": "Compiler",
          "type": "string"
        },
        "demo_digests": {
          "items": {
            "type": "string"
          },
          "title": "Demo Digests",
          "type": "array"
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        },
        "self_test": {
          "$ref": "#/$defs/SelfTestReport"
        }
      },
      "title": "SpecProvenance",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "failure_modes": {
      "items": {
        "$ref": "#/$defs/FailureMode"
      },
      "title": "Failure Modes",
      "type": "array"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "phases": {
      "items": {
        "$ref": "#/$defs/Phase"
      },
      "title": "Phases",
      "type": "array"
    },
    "prompt": {
      "title": "Prompt",
      "type": "string"
    },
    "roles": {
      "items": {
        "$ref": "#/$defs/Role"
      },
      "title": "Roles",
      "type": "array"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "spec_provenance": {
      "$ref": "#/$defs/SpecProvenance"
    },
    "success": {
      "items": {
        "$ref": "#/$defs/Predicate"
      },
      "title": "Success",
      "type": "array"
    },
    "success_sustain_frames": {
      "default": 3,
      "title": "Success Sustain Frames",
      "type": "integer"
    },
    "tl_formula": {
      "default": "",
      "title": "Tl Formula",
      "type": "string"
    },
    "version": {
      "default": 1,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "name",
    "prompt",
    "roles"
  ],
  "title": "TaskSpec",
  "type": "object"
}
